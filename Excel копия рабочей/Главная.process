atalogName="Required" Type="Variable" Value="$TableMacro" Visible="True" DefaultValue="&amp;quot;&amp;quot;" ValueType="DataTable" EnumVariants="{x:Null}" Caption="Таблица" ProtoName="" ReadOnly="False" IsRequired="True" IsPSVerified="True" /&gt;&lt;Property Name="Row" Tooltip="[Число] Номер строки. Нумерация начинается с 0" CatalogName="Required" Type="Expression" Value="$String" Visible="True" DefaultValue="&amp;quot;&amp;quot;" ValueType="Number" EnumVariants="{x:Null}" Caption="Строка" ProtoName="" ReadOnly="False" IsRequired="True" IsPSVerified="True" /&gt;&lt;Property Name="Col" Tooltip="[Число/Текст] Номер или имя столбца. Нумерация начинается с 0" CatalogName="Required" Type="Expression" Value="$MacroStep" Visible="True" DefaultValue="&amp;quot;&amp;quot;" ValueType="Number/Text" EnumVariants="{x:Null}" Caption="Столбец" ProtoName="" ReadOnly="False" IsRequired="True" IsPSVerified="True" /&gt;&lt;Property Name="Value" Tooltip="[Текст/Число] Значение, которое необходимо записать" CatalogName="Required" Type="Expression" Value="$FIOValueMacro" Visible="True" DefaultValue="&amp;quot;&amp;quot;" ValueType="Text/Number" EnumVariants="{x:Null}" Caption="Значение" ProtoName="" ReadOnly="False" IsRequired="True" IsPSVerified="True" /&gt;&lt;Property Name="ErrorLevel" Tooltip="Выбор уровня обработки ошибок. Возможные значения: &amp;quot;Default&amp;quot; - по умолчанию; &amp;quot;Ignore&amp;quot; - ошибки игнорируются; &amp;quot;Handle&amp;quot; - ошибки обрабатываются. Если выбрано значение &amp;quot;Default&amp;quot;, то будет использоваться значение блока &amp;quot;Старт&amp;quot; данной диаграммы" CatalogName="Error processing" Type="Enum" Value="Default" Visible="True" DefaultValue="" ValueType="" EnumVariants="Default;Ignore;Handle" Caption="Уровень обработки" ProtoName="" ReadOnly="False" IsRequired="False" IsPSVerified="True" /&gt;&lt;Property Name="ReportLevel" Tooltip="Выбор уровня сообщений, которые будут выводить блоки при работе. Возможные значения: &amp