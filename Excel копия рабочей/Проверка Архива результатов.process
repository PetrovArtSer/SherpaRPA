      <Content>&lt;ToolboxItemSettings DisplayName="Сортировать список" InternalName="ListSort" FriendlyName="Сортировать список по возрастанию/убыванию или в алфавитном порядке/в обратном алфавитном порядке" Width="200" Height="75" PathToImage="ExternalToolboxes\Image\ico_Collections.png" PathToToolboxImage="{x:Null}" ImageType="LeftImage" NoDelete="False" Invisible="False" Proportional="True" Version="11" LinuxAvailable="True" Code="&amp;#xA;function ListSort{{{block_id}}}&amp;#xA;{         &amp;#xA; try&amp;#xA; {&amp;#xA;    $__Error.Enter(&amp;quot;{{{block_native_id}}}&amp;quot;, &amp;quot;{{{ErrorLevel}}}&amp;quot;,&amp;quot;{{{ErrorDirection}}}&amp;quot;,&amp;quot;{{{ReportLevel}}}&amp;quot;,&amp;quot;{{{ErrorMessage}}}&amp;quot;);&amp;#xA;    $__Error.AddConnectors(&amp;quot;{{{connector-Error}}}&amp;quot;, &amp;quot;{{{connectorRight}}}&amp;quot;, &amp;quot;{{{connectorBottom}}}&amp;quot;);&amp;#xA;    &amp;#xA;        if(&amp;quot;{{{Direction}}}&amp;quot; -eq &amp;quot;Ascending&amp;quot;)&amp;#xA;        {         &amp;#xA;            {{{Items}}}.Sort();&amp;#xA;        }&amp;#xA;        else&amp;#xA;        {&amp;#xA;            {{{Items}}}.Sort();&amp;#xA;            {{{Items}}}.Reverse();&amp;#xA;        }&amp;#xA;    }&amp;#xA;    catch &amp;#xA;    { &amp;#xA;        $__Error.ExceptionCatch($_);&amp;#xA;        return;&amp;#xA;    }&amp;#xA;    $__Error.Quit();&amp;#xA;}&amp;#xA;" ProtoName="" TextColor="#FFDADADA" Language="" UrlVideo="{x:Null}" DerivedFrom="" NoResize="False" Container="False" MouseOverColor="Gray" MouseOverFill="Transparent" IsExpressionOnPause="False" ExpressionOnPause="" IsCollapsedBlock="False" Breakpoint="False" DirivedFrom="" xmlns="clr-namespace:ToolboxDesigner.Core;assembly=DiagramDesigner" xmlns:av="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:s="clr-namespace:System;assembly=mscorlib" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"&gt;&lt;ToolboxItemSettings.PathStyle&gt;&lt;av:Style TargetTyp