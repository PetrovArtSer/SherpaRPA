   }  &amp;#xA;            &amp;#xA;            $_Table.Rows[$indexRow][$indexCol] = $_Value;&amp;#xA;        }         &amp;#xA;        else &amp;#xA;        {          &amp;#xA;            $nameCol = $_Col;&amp;#xA;            &amp;#xA;            $valuetype = $nameCol.GetType();&amp;#xA;            if($null -ne $_Value) { $valuetype = $_Value.GetType(); } &amp;#xA;        &amp;#xA;            if(-not $_Table.Columns.Contains($nameCol))&amp;#xA;            {&amp;#xA;                $_Table.Columns.Add($nameCol, $valuetype); &amp;#xA;            }   &amp;#xA;            &amp;#xA;            while ($indexRow -ge $_Table.Rows.Count)&amp;#xA;            {&amp;#xA;                $newrow = $_Table.NewRow();&amp;#xA;                $_      = $_Table.Rows.Add($newrow);&amp;#xA;            } &amp;#xA;            &amp;#xA;            $_Table.Rows[$indexRow][$nameCol] = $_Value;&amp;#xA;        }             &amp;#xA;    }&amp;#xA;    catch &amp;#xA;    { &amp;#xA;        $__Error.ExceptionCatch($_);&amp;#xA;        return;&amp;#xA;    }&amp;#xA;    $__Error.Quit();&amp;#xA;}                   &amp;#xA;                " ProtoName="" TextColor="#FFDADADA" Language="" UrlVideo="{x:Null}" DerivedFrom="" NoResize="False" Container="False" MouseOverColor="Gray" MouseOverFill="Transparent" IsExpressionOnPause="False" ExpressionOnPause="" IsCollapsedBlock="False" Breakpoint="False" DirivedFrom="" xmlns="clr-namespace:ToolboxDesigner.Core;assembly=DiagramDesigner" xmlns:av="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:s="clr-namespace:System;assembly=mscorlib" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"&gt;&lt;ToolboxItemSettings.PathStyle&gt;&lt;av:Style TargetType="av:Path"&gt;&lt;av:Style.BasedOn&gt;&lt;av:Style TargetType="av:Path"&gt;&lt;av:Style.Resources&gt;&lt;av:ResourceDictionary /&gt;&lt;/av:Style.Resources&gt;&lt;av:Setter Property="av:Shape.Fill"&gt;&lt;av:Setter.Value&gt;&lt;av:SolidColorBrush&gt;#FF252525&lt;/av:SolidColorBrush&gt;&lt;/